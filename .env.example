# Core
DATABASE_URL=postgres://user:pass@localhost:5432/aggregator
REDIS_URL=redis://localhost:6379

# API
API_PORT=3000

# Ingestion
POLL_INTERVAL_MS=30000
IPFS_GATEWAY=https://gateway.pinata.cloud

# Fuji (Avalanche C-Chain testnet) RPC ingestion
CHAIN_ID=43113
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Log scanning cursor
INGEST_FROM_BLOCK=51544615
INGEST_LOG_CHUNK_BLOCKS=5000
INGEST_CONFIRMATIONS=3

# Trust engine
TRUST_MIN_SCORE=60
# Comma-separated addresses treated as verified watchtowers
WATCHTOWER_ALLOWLIST=

# Trust engine (optional)
TRUST_REFRESH_INTERVAL_MS=300000

# Score calculator (optional)
SCORE_REFRESH_INTERVAL_MS=60000
SCORE_BATCH_SIZE=100

# Sybil detection (score-calculator)
SYBIL_DETECT_ENABLED=1
SYBIL_BURST_WINDOW_SEC=3600
SYBIL_BURST_THRESHOLD=10
